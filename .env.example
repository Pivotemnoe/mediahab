APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://media_hub:media_hub@postgres:5432/media_hub
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000,http://localhost:3100,http://127.0.0.1:3100
SESSION_COOKIE_SECURE=false
ADMIN_API_TOKEN=local-admin-token
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_BASE_URL=http://localhost:9100
S3_BUCKET=media-hub-local
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=mediahub
S3_SECRET_ACCESS_KEY=mediahub-password
S3_FORCE_PATH_STYLE=true
MEDIA_STORAGE_PREFIX=media-hub-local
STT_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_LANGUAGE=ru
OPENAI_STT_TIMEOUT_SECONDS=60
AI_TEXT_PROVIDER=openai
AI_TEXT_MODEL=mock-editor-v1
AI_TEXT_TIMEOUT_SECONDS=90
OPENAI_TEXT_MODEL=gpt-4.1-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=mock-embedding-v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
NEXT_PUBLIC_API_BASE_URL=http://localhost:8100/api/v1
