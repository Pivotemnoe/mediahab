{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://temichev.media/schemas/platform-policy.schema.json",
  "title": "Connector-owned platform policy",
  "type": "object",
  "required": [
    "schema_version",
    "platform",
    "connector_status",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "policy_checked_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "connector_status": {
      "type": "string"
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": true
    },
    "hard_limits": {
      "type": "object",
      "additionalProperties": true
    },
    "modes": {
      "type": "object",
      "additionalProperties": true
    },
    "source_docs": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "implementation_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
